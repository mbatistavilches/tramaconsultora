---
// Aquí puedes definir variables si quieres, por ahora lo dejamos simple.
const links = [
	{ name: "Nuestros Servicios (PDF)", url: "#" },
	{ name: "Instagram", url: "https://instagram.com/trama.agroecologia" },
	{ name: "WhatsApp", url: "https://wa.me/tu_numero" },
	{ name: "Diagnóstico GIS", url: "#" }
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>TRAMA - Consultora Ambiental</title>
	</head>
	<body>
		<main>
			<h1>TRAMA</h1>
			<p>Paisajes Productivos y Resilientes</p>
			
			<div class="container">
				{links.map(link => (
					<a href={link.url} class="button">{link.name}</a>
				))}
			</div>
		</main>

		<style>
			body { background: #f4f1ea; font-family: system-ui; display: flex; justify-content: center; padding: 2rem; color: #2d3e24; }
			main { max-width: 400px; width: 100%; text-align: center; }
			.container { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
			.button { background: #97b968; color: white; padding: 1rem; border-radius: 8px; text-decoration: none; font-weight: bold; transition: 0.2s; }
			.button:hover { background: #7a9a52; transform: translateY(-2px); }
		</style>
	</body>
</html>
