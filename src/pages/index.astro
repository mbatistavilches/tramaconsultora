---
// TRAMA - Versión Final Estable Corregida
const bgColor = "#48542B"; 
const darkGreen = "#3a4a2c";
const accentGreen = "#acc670";

const services = [
    { 
        id: 1, 
        title: "Relevamiento y Mapeo", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
        details: ["Cartografía base de alta resolución", "Monitoreo satelital (Sentinel-2)", "Topografía digital", "Índices NDVI/ MSAVI2/ NDRE/ NDMI/ NDBI/ etc."], 
        img: "/data/servicio_1.jpg" 
    },
    { 
        id: 2, 
        title: "Caminería Rural", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 18-2-1-5 2V7l5-2 4 2 5-2v12l-5 2-3-1Z"/><path d="M9 5v12"/><path d="M15 7v12"/></svg>`,
        details: ["Trazado óptimo según relieve", "Integración con drenajes", "Planos de detalle"], 
        img: "/data/servicio_2.jpg" 
    },
    { 
        id: 3, 
        title: "Gestión del Agua", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
        details: ["Identificación de microcuencas", "Cosecha de agua", "Sistemas de riego"], 
        img: "/data/servicio_3.jpg" 
    },
    { 
        id: 4, 
        title: "Prevención de Incendios", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
        details: ["Mapas de riesgo", "Cortafuegos productivos", "Planes de restauración"], 
        img: "/data/servicio_4.jpg" 
    },
    { 
        id: 5, 
        title: "Planificación Agroecológica", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-6.4 8-12"/><path d="M14 20c-5.5-2.5-8-6.4-8-12"/><path d="M12 4v16"/></svg>`,
        details: ["Diseño integral de campos", "Diagnóstico de fertilidad", "Sistemas silvopastoriles"], 
        img: "/data/servicio_5.jpg" 
    },
    { 
        id: 6, 
        title: "Análisis Territorial", 
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
        details: ["Modelos 3D", "Informes técnicos", "Estudios de impacto visual"], 
        img: "/data/servicio_6.jpg" 
    }
];
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRAMA - Paisajes Agroecológicos</title>
    <style define:vars={{ bgColor, darkGreen, accentGreen }}>
        @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');
        
        body { 
            font-family: 'Open Sans', sans-serif; 
            background-color: var(--bgColor); 
            color: white; 
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        header { width: 100%; max-width: 500px; text-align: center; padding: 40px 20px; z-index: 10; box-sizing: border-box; }
        .logo { max-width: 180px; height: auto; margin-bottom: 15px; }
        .tagline { font-style: italic; color: rgba(255,255,255,0.7); font-size: 0.9rem; margin: 0; }

        /* Contenedor de Servicios */
        .services-section { width: 100%; max-width: 450px; padding: 0 20px; margin-bottom: 40px; z-index: 10; box-sizing: border-box; }
        .section-title { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.5); margin-bottom: 15px; text-align: center; }

        details { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; margin-bottom: 12px; backdrop-filter: blur(5px); }
        summary { padding: 20px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; transition: background 0.3s; }
        summary:hover { background: rgba(255, 255, 255, 0.1); }
        summary::after { content: '+'; font-size: 1.2rem; color: var(--accentGreen); }
        details[open] summary::after { content: '−'; }
        
        .details-content { padding: 0 20px 20px 20px; font-size: 0.9rem; color: rgba(255,255,255,0.8); }
        .details-content ul { padding-left: 20px; margin: 0 0 15px 0; }
        .service-img { width: 100%; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); margin-top: 10px; }

        /* Botones Unificados y Responsivos */
        footer { width: 100%; max-width: 450px; padding: 20px; text-align: center; z-index: 10; margin-bottom: 60px; box-sizing: border-box; }
        .btn { 
            display: flex; align-items: center; justify-content: center; 
            width: 100%; /* Ancho completo del contenedor */
            padding: 18px; border-radius: 16px; margin-bottom: 15px; 
            text-decoration: none; color: white; font-weight: 700; 
            box-sizing: border-box; /* Importante para que el padding no desborde */
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .btn:hover { transform: translateY(-5px) scale(1.02); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }
        .whatsapp { background-color: #25D366; }
        .instagram { background-color: #E4405F; }

        .bg-element {
            position: fixed;
            bottom: 0;
            right: 0;
            max-width: 300px;
            width: 60%;
            height: auto;
            pointer-events: none;
            z-index: 1;
            opacity: 0.6;
        }

        @media (max-width: 600px) { .bg-element { max-width: 200px; } }
summary { 
    padding: 20px; 
    font-weight: 700; 
    cursor: pointer; 
    list-style: none; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    transition: background 0.3s; 
}
summary::-webkit-details-marker { display: none; } /* Oculta la flecha por defecto en Safari */
    </style>
<meta property="og:type" content="website" />
<meta property="og:url" content="https://tramaconsultora.com.ar/" />
<meta property="og:title" content="TRAMA - Paisajes Productivos y Regeneración" />
<meta property="og:description" content="Diseño y planificación de paisajes productivos aplicando principios ecológicos en la Patagonia." />
<meta property="og:image" content="https://tramaconsultora.com.ar/og-image.png" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://tramaconsultora.com.ar/" />
<meta property="twitter:title" content="TRAMA - Paisajes Productivos y Regeneración" />
<meta property="twitter:description" content="Especialistas en diseño hidrológico, ganadería regenerativa y mapas de riesgo." />
<meta property="twitter:image" content="https://tramaconsultora.com.ar/og-image.png" />
</head>
<body>

    <header>
        <img src="/logo.png" alt="Trama" class="logo" />
        <p class="tagline">"Cada territorio tiene una trama que espera ser regenerada."</p>
    </header>

    <main class="services-section">
        <p class="section-title">Servicios Técnicos</p>
        {services.map(s => (
            <details name="servicios">
                <summary>{s.title}</summary>
                <div class="details-content">
                    <ul>
                        {s.details.map(d => <li>{d}</li>)}
                    </ul>
                    <img src={s.img} alt={s.title} class="service-img" onerror="this.style.display='none'" />
                </div>
            </details>
        ))} 
    </main>

    <footer>
        <a href="https://wa.me/5491155119496?text=Hola%20llegu%C3%A9%20ac%C3%A1%20desde%20la%20web" target="_blank" class="btn whatsapp">
            Contactar
        </a>
        <a href="https://instagram.com/trama.paisajes" target="_blank" class="btn instagram">
            Seguir en redes
        </a>
        <p style="font-size: 0.7rem; opacity: 0.5; margin-top: 20px; font-weight: 800; letter-spacing: 2px;">TRAMA · PATAGONIA</p>
    </footer>

    <img src="https://raw.githubusercontent.com/mbatistavilches/tramaconsultora/main/public/trama-topo.png" alt="" class="bg-element" />

</body>
</html>
