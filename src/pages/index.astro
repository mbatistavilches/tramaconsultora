---
// TRAMA - Web Unificada (Linktree + Servicios Interactivos)
---
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRAMA - Paisajes Agroecológicos</title>
    <meta property="og:title" content="TRAMA - Paisajes Agroecológicos" />
    <meta property="og:description" content="Diseño y planificación de paisajes productivos y resilientes en la Patagonia." />
    <meta property="og:image" content="https://tramaconsultora.com.ar/og-image.png" />
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #FDFCF8; color: #3a4a2c; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script is:inline>
        const services = [
            { id: 1, title: "Relevamiento y Mapeo", details: ["Cartografía base de alta resolución", "Monitoreo satelital (Sentinel-2)", "Topografía digital", "Índices NDVI"], color: "bg-stone-100" },
            { id: 2, title: "Caminería Rural", details: ["Trazado óptimo según relieve", "Integración con drenajes", "Planos de detalle"], color: "bg-stone-100" },
            { id: 3, title: "Gestión del Agua", details: ["Identificación de microcuencas", "Cosecha de agua", "Sistemas de riego"], color: "bg-blue-50" },
            { id: 4, title: "Prevención de Incendios", details: ["Mapas de riesgo", "Cortafuegos productivos", "Planes de restauración"], color: "bg-orange-50" },
            { id: 5, title: "Planificación Agroecológica", details: ["Diseño integral de campos", "Diagnóstico de fertilidad", "Sistemas silvopastoriles"], color: "bg-green-100" },
            { id: 6, title: "Análisis Territorial", details: ["Modelos 3D", "Informes técnicos", "Estudios de impacto visual"], color: "bg-slate-100" }
        ];

        function App() {
            const [activeTab, setActiveTab] = React.useState(null);

            const e = React.createElement;

            return e('div', { className: 'min-h-screen flex flex-col' }, [
                // Header con Logo
                e('header', { className: 'bg-white px-6 pt-10 pb-8 border-b border-stone-100 flex flex-col items-center' }, [
                    e('img', { src: '/logo.png', className: 'w-full max-w-[250px] h-auto mb-4' }),
                    e('p', { className: 'text-center text-sm italic text-stone-500 max-w-xs' }, 
                        '"Cada territorio tiene una trama que espera ser regenerada."'
                    )
                ]),

                // Hero interactivo
                e('section', { className: 'px-6 py-8' }, 
                    e('div', { className: 'bg-[#3a4a2c] rounded-3xl p-7 text-white shadow-xl' }, [
                        e('h2', { className: 'text-2xl font-bold mb-2' }, 'Planificación Predial'),
                        e('p', { className: 'text-white/80 text-sm leading-relaxed' }, 
                            'Tecnología de precisión y principios regenerativos para tu territorio.'
                        )
                    ])
                ),

                // Lista de Servicios (Acordeón)
                e('main', { className: 'px-6 space-y-4 flex-grow' }, [
                    e('h3', { className: 'text-[10px] font-bold uppercase tracking-widest text-stone-400 mb-2' }, 'Nuestros Servicios'),
                    services.map(s => e('div', { key: s.id, className: 'rounded-2xl border border-stone-100 bg-white overflow-hidden shadow-sm' }, [
                        e('button', { 
                            className: 'w-full text-left p-5 flex items-center justify-between',
                            onClick: () => setActiveTab(activeTab === s.id ? null : s.id)
                        }, [
                            e('div', { className: 'flex items-center gap-4' }, [
                                e('div', { className: `p-2 rounded-lg ${s.color}` }, '•'),
                                e('span', { className: 'font-bold text-base' }, s.title)
                            ]),
                            e('span', { className: `text-xl transition-transform ${activeTab === s.id ? 'rotate-45' : ''}` }, '+')
                        ]),
                        activeTab === s.id && e('div', { className: 'px-14 pb-6 animate-in fade-in' }, 
                            e('ul', { className: 'space-y-2' }, 
                                s.details.map(d => e('li', { key: d, className: 'text-sm text-stone-600 flex items-center gap-2' }, [
                                    e('span', { className: 'text-[#acc670]' }, '✓'), d
                                ]))
                            )
                        )
                    ]))
                ]),

                // Footer con Botones de Contacto
                e('footer', { className: 'px-6 py-12 bg-white mt-12 border-t border-stone-100 text-center' }, [
                    e('h4', { className: 'font-bold text-lg mb-6' }, 'Comencemos tu regeneración'),
                    e('div', { className: 'flex flex-col gap-4 max-w-sm mx-auto' }, [
                        e('a', { 
                            href: "https://wa.me/5491155119496?text=Hola%20llegu%C3%A9%20ac%C3%A1%20desde%20la%20web",
                            target: "_blank",
                            className: 'bg-[#25D366] text-white py-4 rounded-2xl font-bold flex items-center justify-center gap-3 shadow-lg hover:scale-105 transition-transform no-underline'
                        }, 'WhatsApp'),
                        e('a', { 
                            href: "https://instagram.com/trama.agroecologia",
                            target: "_blank",
                            className: 'bg-[#E4405F] text-white py-4 rounded-2xl font-bold flex items-center justify-center gap-3 shadow-lg hover:scale-105 transition-transform no-underline'
                        }, 'Instagram')
                    ]),
                    e('p', { className: 'mt-10 text-[10px] text-stone-400 font-bold uppercase tracking-widest' }, 
                        'Trama · El Bolsón, Patagonia'
                    )
                ])
            ]);
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(e(App));
    </script>
</body>
</html>
