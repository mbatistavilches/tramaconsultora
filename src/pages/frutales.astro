---
// TRAMA - Sub-web Manejo de Frutales
import podasData from '../data/podas_comarca.json'; // Movido a src/data/ para que el build funcione

const bgColor = "#48542B"; 
const accentGreen = "#acc670";

// Procesamos los puntos en el servidor
const puntosLimpios = podasData.features.map(f => ({
    lat: f.geometry.coordinates[1],
    lng: f.geometry.coordinates[0]
})).filter(p => p.lat && p.lng);
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manejo de Frutales - TRAMA</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />

    <style define:vars={{ bgColor, accentGreen }}>
        @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap');
        body { font-family: 'Open Sans', sans-serif; background-color: var(--bgColor); color: white; margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        header { width: 100%; max-width: 500px; text-align: center; padding: 30px 20px; }
        .back-link { text-decoration: none; color: var(--accentGreen); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
        .hero { padding: 20px; text-align: center; max-width: 450px; }
        h1 { font-size: 1.8rem; margin-bottom: 10px; }
        .subtitle { font-style: italic; opacity: 0.8; font-size: 1rem; margin-bottom: 30px; }
        .diff-box { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 20px; border-left: 4px solid var(--accentGreen); margin: 0 20px 40px 20px; font-size: 0.9rem; max-width: 400px; }
        .pack-card { background: white; color: var(--bgColor); border-radius: 24px; padding: 25px; margin-bottom: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); position: relative; width: 90%; max-width: 400px;}
        .pack-tag { position: absolute; top: -12px; right: 20px; background: var(--accentGreen); color: var(--bgColor); padding: 4px 12px; border-radius: 20px; font-weight: 800; font-size: 0.7rem; }
        #map { height: 400px; width: 90%; max-width: 450px; border-radius: 24px; margin: 20px 0; border: 2px solid rgba(255,255,255,0.1); z-index: 1; }
        footer { width: 100%; max-width: 450px; padding: 40px 20px; text-align: center; box-sizing: border-box; }
        .btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 18px; border-radius: 16px; margin-bottom: 15px; text-decoration: none; color: white; font-weight: 700; box-sizing: border-box; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .whatsapp { background-color: #25D366; }
        .instagram { background-color: #E4405F; }
    </style>
</head>
<body>
    <header><a href="/" class="back-link">← Volver al Menú</a></header>

    <section class="hero">
        <h1>Manejo de Frutales</h1>
        <p class="subtitle">De mano de obra especializada a aliado productivo.</p>
    </section>

    <div class="pack-card">
        <span class="pack-tag">MÁS ELEGIDO</span>
        <h3>Pack Inicial</h3>
        <p style="font-size: 0.9rem;">Poda + Diagnóstico Escrito.</p>
    </div>

    <section style="width: 100%; display: flex; flex-direction: column; align-items: center;">
        <p style="font-size: 0.7rem; font-weight: 800; opacity: 0.5; letter-spacing: 2px;">NUESTRA HUELLA EN LA COMARCA</p>
        <div id="map"></div>
    </section>

    <footer>
        <a href="https://wa.me/5491155119496" target="_blank" class="btn whatsapp">Consultar Presupuesto</a>
        <a href="https://instagram.com/trama.paisajes" target="_blank" class="btn instagram">Instagram</a>
    </footer>

    <script define:vars={{ puntosLimpios }}>
        window.PUNTOS_TRAMA = puntosLimpios;
    </script>

    <script is:inline>
        function loadJS(src) {
            return new Promise((resolve) => {
                const s = document.createElement('script');
                s.src = src;
                s.onload = resolve;
                document.head.appendChild(s);
            });
        }

        async function init() {
            if (typeof L === 'undefined') {
                await loadJS('https://unpkg.com/leaflet@1.9.4/dist/leaflet.js');
                await loadJS('https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js');
            }

            const map = L.map('map', { scrollWheelZoom: false }).setView([-41.96, -71.53], 11);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

            const markers = L.markerClusterGroup({ showCoverageOnHover: false });
            const tramaIcon = L.divIcon({
                className: "trama-marker",
                html: `<div style="background:#acc670;width:12px;height:12px;border-radius:50%;border:2px solid #48542B;"></div>`
            });

            if (window.PUNTOS_TRAMA) {
                window.PUNTOS_TRAMA.forEach(p => {
                    markers.addLayer(L.marker([p.lat, p.lng], { icon: tramaIcon }));
                });
                map.addLayer(markers);
                setTimeout(() => {
                    map.invalidateSize();
                    if (markers.getBounds().isValid()) {
                        map.fitBounds(markers.getBounds(), { padding: [30, 30] });
                    }
                }, 500);
            }
        }

        window.onload = init;
    </script>
</body>
</html>
